# Публичный URL сайта (без слэша в конце)
NUXT_PUBLIC_SITE_URL=https://unionconsulting.ru

# Имя бренда: полное и короткое (PWA manifest, SEO)
NUXT_PUBLIC_SITE_NAME=Union Consulting Group
NUXT_PUBLIC_SITE_SHORT_NAME=Union

# Телефон: как показывать в UI и значение для tel:
NUXT_PUBLIC_CONTACT_PHONE=+7 (495) 000-00-00
NUXT_PUBLIC_CONTACT_PHONE_HREF=+74950000000

# Опционально: ISO-время сборки для JSON-LD WebPage.dateModified (задаётся в CI)
# NUXT_PUBLIC_BUILD_TIME=2026-04-06T12:00:00.000Z

# Уведомления о заявках с формы (серверный API /api/application). Токен не коммитить.
# TELEGRAM_BOT_TOKEN=123456789:AA...
# TELEGRAM_CHAT_ID=-1001234567890
